generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String?  @unique
  githubId  String   @unique
  login     String
  name      String?
  avatarUrl String?
  createdAt DateTime @default(now())
  token     GitHubAccountToken?
  personalAccessToken GitHubPersonalAccessToken?
  repositories TrackedRepository[]
}

model GitHubAccountToken {
  userId        String   @id
  encryptedToken String
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model GitHubPersonalAccessToken {
  userId         String   @id
  encryptedToken String
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TrackedRepository {
  id             String            @id @default(cuid())
  repoId         String
  repoName       String
  installationId Int?
  ownerLogin     String
  enabled        Boolean           @default(true)
  webhookConfigured Boolean        @default(false)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  userId         String
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  integration    RepoIntegration?

  @@unique([userId, repoId])
}

model AnalysisRun {
  id             String   @id @default(cuid())
  repositoryId   String
  prNumber       Int
  attentionLevel String
  confidence     Float
  createdAt      DateTime @default(now())
}

model RepoIntegration {
  id                String            @id @default(cuid())
  trackedRepositoryId String          @unique
  slackWebhookUrl   String?
  discordWebhookUrl String?
  updatedAt         DateTime          @updatedAt
  trackedRepository TrackedRepository @relation(fields: [trackedRepositoryId], references: [id], onDelete: Cascade)
}
